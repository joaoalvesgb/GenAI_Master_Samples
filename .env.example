# ============================================
# GenAI Master Samples - Configuração
# ============================================
# Copie este arquivo para .env e preencha suas chaves:
# cp .env.example .env
# ============================================

# ============================================
# LLM APIs (pelo menos uma é obrigatória)
# ============================================

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-sua-chave-aqui

# Google Gemini - https://aistudio.google.com/apikey
GOOGLE_API_KEY=sua-chave-aqui

# Azure OpenAI - https://portal.azure.com
# AZURE_OPENAI_API_KEY=sua-chave-aqui
# AZURE_OPENAI_ENDPOINT=https://seu-recurso.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ============================================
# APIs de Tools (opcionais)
# ============================================

# Alpha Vantage (ações/forex) - https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=sua-chave-aqui

# Tavily (busca web alternativa) - https://tavily.com
# TAVILY_API_KEY=sua-chave-aqui

# ============================================
# Configuração da API (opcionais)
# ============================================

# Porta da API (padrão: 8000)
# API_PORT=8000

# Autenticação (padrão: false)
# API_AUTH_REQUIRED=false
# API_AUTH_KEY=sua-chave-secreta

# ============================================
# Configuração de Busca Web (opcionais)
# ============================================

# Provider de busca: duckduckgo, tavily, wikipedia
# SEARCH_PROVIDER=duckduckgo

# ============================================
# Configuração de Embeddings (opcionais)
# ============================================

# Provedor de embeddings: openai, azure, gemini, ollama, huggingface
# Se não definido, detecta automaticamente pelas API keys configuradas
# EMBEDDING_PROVIDER=openai

# Modelo de embeddings (depende do provedor escolhido)
# Se não definido, usa o padrão de cada provedor
#
# Exemplos por provedor:
#   OpenAI:      text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
#   Azure:       text-embedding-3-small (nome do deployment no Azure)
#   Gemini:      models/text-embedding-004, models/embedding-001
#   Ollama:      nomic-embed-text, mxbai-embed-large, all-minilm
#   HuggingFace: sentence-transformers/all-MiniLM-L6-v2, sentence-transformers/all-mpnet-base-v2
# EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI Embedding endpoint (caso seja diferente do AZURE_OPENAI_ENDPOINT)
# Se não definido, usa o AZURE_OPENAI_ENDPOINT como fallback
# AZURE_OPENAI_EMBEDDING_ENDPOINT=https://meu-recurso-embedding.openai.azure.com

# URL do Ollama (caso use um servidor remoto)
# OLLAMA_BASE_URL=http://localhost:11434
